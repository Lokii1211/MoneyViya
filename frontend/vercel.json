{
  "rewrites": [
    { "source": "/api/webhook", "destination": "/api/webhook.js" },
    { "source": "/api/cron/check-reminders", "destination": "/api/cron/check-reminders.js" },
    { "source": "/((?!api|assets).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/check-reminders", "schedule": "* * * * *" }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite"
}