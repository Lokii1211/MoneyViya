        "sp_6":  24,
        "sp_8":  32,
        "sp_10": 40,
        "sp_12": 48,
        "sp_16": 64,
        "sp_20": 80
      },
      "screen_margin": {
        "standard": 20,
        "large_android": 24
      },
      "safe_areas": "Always respected — iOS notch/home indicator, Android navigation bar"
    },

    "border_radius": {
      "r_xs":   6,
      "r_sm":   10,
      "r_md":   14,
      "r_lg":   18,
      "r_xl":   22,
      "r_2xl":  28,
      "r_full": 9999
    },

    "shadows": {
      "sh_1": "0 1px 3px rgba(0,0,0,0.04)",
      "sh_2": "0 4px 8px rgba(0,0,0,0.06), 0 1px 3px rgba(0,0,0,0.04)",
      "sh_3": "0 8px 20px rgba(0,0,0,0.08), 0 2px 6px rgba(0,0,0,0.04)",
      "sh_4": "0 16px 32px rgba(0,0,0,0.12), 0 4px 8px rgba(0,0,0,0.06)",
      "sh_5": "0 24px 48px rgba(0,0,0,0.16)",
      "sh_brand":   "0 8px 28px rgba(0,229,176,0.30)",
      "sh_cosmos":  "0 8px 28px rgba(85,20,255,0.25)",
      "sh_gold":    "0 8px 28px rgba(255,224,26,0.35)",
      "sh_emerald": "0 8px 28px rgba(0,232,126,0.30)",
      "sh_coral":   "0 8px 28px rgba(255,80,64,0.25)"
    }
  },

  "motion_system": {
    "philosophy": "Motion communicates state, rewards behavior, builds trust. Never decorative. Never delayed.",
    "performance_rule": "All animations run on UI thread (Reanimated 3 worklets). 60fps non-negotiable.",
    "forbidden": ["animate width", "animate height", "animate padding", "animate margin", "animate top/left"],
    "allowed": ["transform.scale", "transform.translateX", "transform.translateY", "transform.rotate", "opacity"],

    "spring_configs": {
      "default":  { "damping": 18, "stiffness": 200, "mass": 1.0 },
      "bouncy":   { "damping": 10, "stiffness": 180, "mass": 1.0 },
      "tight":    { "damping": 25, "stiffness": 300, "mass": 1.0 },
      "slow":     { "damping": 20, "stiffness": 120, "mass": 1.2 },
      "overshoot":{ "damping": 8,  "stiffness": 150, "mass": 1.0 }
    },

    "easing": {
      "ease_out": "cubic-bezier(0.0, 0.0, 0.2, 1.0)",
      "ease_in":  "cubic-bezier(0.4, 0.0, 1.0, 1.0)",
      "standard": "cubic-bezier(0.4, 0.0, 0.2, 1.0)",
      "never_use": "linear — mechanical and inhuman"
    },

    "durations": {
      "micro":       { "range": "80-100ms",   "use": "Icon swaps, state indicator changes" },
      "quick":       { "range": "150-180ms",  "use": "Button press feedback" },
      "standard":    { "range": "250-280ms",  "use": "Screen transitions, card expand" },
      "deliberate":  { "range": "320-380ms",  "use": "Modal sheets, onboarding transitions" },
      "celebration": { "range": "500-2000ms", "use": "Achievement unlocks, goal completion" }
    },

    "animations": {
      "viya_orb_idle": {
        "name": "Breathing",
        "property": "scale",
        "keyframes": [1.0, 1.04, 1.0],
        "duration": 3500,
        "easing": "ease-in-out",
        "repeat": "infinite",
        "description": "Subtle breathing shows Viya is alive and present"
      },
      "viya_orb_thinking": {
        "name": "AI Processing",
        "property": ["scale", "color"],
        "keyframes_scale": [1.0, 1.1, 1.0],
        "duration": 800,
        "easing": "tight_spring",
        "repeat": "while_processing",
        "color_shift": "teal_500 → cosmos_500",
        "description": "Faster pulse + color shift signals AI is working"
      },
      "viya_orb_success": {
        "name": "Completion Flash",
        "property": "scale",
        "keyframes": [1.0, 1.2, 1.0],
        "duration": 400,
        "easing": "tight_spring",
        "color_flash": "emerald_500",
        "flash_duration": 200,
        "haptic": "notificationSuccess",
        "description": "Brief celebration when action completes"
      },
      "button_press": {
        "name": "Physical Press",
        "touch_down": { "scale": 0.96, "duration": 80, "easing": "ease-in" },
        "touch_up":   { "scale": 1.01, "duration": 120, "easing": "spring_default" },
        "settle":     { "scale": 1.0,  "duration": 60,  "easing": "tight_spring" },
        "haptic": "impact_light",
        "description": "Makes digital buttons feel physical"
      },
      "number_count_up": {
        "name": "Financial Count",
        "method": "frame-by-frame interpolation",
        "duration": 700,
        "easing": "ease-out",
        "overshoot_pct": 3,
        "color_flash_positive": { "color": "emerald_500", "opacity_keyframes": [0, 1, 0], "duration": 150 },
        "color_flash_negative": { "color": "coral_500",   "opacity_keyframes": [0, 1, 0], "duration": 150 },
        "description": "Numbers animate to new value — satisfaction in watching money change"
      },
      "progress_bar_fill": {
        "name": "Goal Progress",
        "mount_animation": "0% → current_value",
        "duration": 800,
        "easing": "ease-out",
        "milestone_pulse": {
          "triggers": ["25%", "50%", "75%", "100%"],
          "scale_y": [1.0, 1.02, 1.0],
          "duration": 400
        },
        "milestone_dot_entrance": {
          "scale": [0, 1.3, 1.0],
          "spring": "bouncy",
          "duration": 400
        }
      },
      "streak_milestone": {
        "name": "Streak Fire",
        "day_added": {
          "translateY": [0, -12, 0],
          "scale": [1.0, 1.4, 1.0],
          "duration": 400,
          "spring": "bouncy"
        },
        "milestone_7_14_21_30": {
          "background_sweep": "gold gradient left to right, 1s",
          "fire_scale": [1.0, 2.5],
          "particles": 8,
          "particle_type": "fire emojis",
          "haptic": "impact_heavy"
        }
      },
      "goal_completion_celebration": {
        "name": "Achievement Explosion",
        "trigger": "goal.current_amount >= goal.target_amount",
        "phases": {
          "phase_1_ms_0_400": "Gold overlay fades in (opacity 0→0.9), achievement card scales from center (spring 0→1.05→1)",
          "phase_2_ms_400_1200": "Confetti burst: 60 particles, brand colors (#FFD700 #00E5B0 #5514FF #FF5040), physics simulation",
          "phase_3_ms_1200_plus": "Text reveals line by line (100ms stagger), CTA button pulses for attention"
        },
        "haptic_sequence": ["notificationSuccess", "300ms pause", "notificationSuccess"],
        "auto_dismiss_after": 5000,
        "confetti": {
          "count": 60,
          "colors": ["#FFD700", "#00E5B0", "#5514FF", "#FF5040"],
          "shapes": ["circle", "square", "teardrop"],
          "physics": "gravity + random velocity + rotation"
        }
      },
      "chat_message_viya": {
        "name": "Message Arrive",
        "translateX": -12,
        "opacity": [0, 1],
        "duration": 200,
        "spring": "default"
      },
      "chat_message_user": {
        "name": "Message Send",
        "translateX": 12,
        "opacity": [0, 1],
        "duration": 150,
        "spring": "tight"
      },
      "typing_indicator": {
        "name": "Viya Thinking",
        "delay_before_show": 600,
        "dots_count": 3,
        "each_dot_translateY": [0, -6, 0],
        "stagger_ms": 120,
        "repeat": "infinite"
      },
      "screen_transition_push": {
        "new_screen": { "translateX": "100%→0", "duration": 280, "easing": "ease-out" },
        "old_screen": { "translateX": "0→-30%", "duration": 280, "easing": "ease-out", "note": "Parallax effect" }
      },
      "modal_open": {
        "sheet": { "translateY": "100%→0", "duration": 350, "spring": "spring(damping=0.85, stiffness=200)" },
        "backdrop": { "opacity": "0→0.5", "duration": 250 }
      },
      "pull_to_refresh": {
        "viya_orb_appears": "scales from 0→1 as user pulls (scale = pull_distance / 72)",
        "at_threshold_72dp": "orb begins rotation animation",
        "on_release": "orb spins 1 rotation, Syncing text appears",
        "on_complete": "checkmark morphs inside orb, content fades in fresh"
      }
    }
  },

  "screens": {
    "splash": {
      "id": "SL-001",
      "priority": "P1-CRITICAL",
      "duration_max_ms": 1500,
      "background": "gradient-night",
      "elements": {
        "orb": { "size": 96, "animation": "viya_orb_idle", "shadow": "sh_brand" },
        "title": { "text": "VIYA", "style": "hero", "color": "white", "letter_spacing": 6 },
        "subtitle": { "text": "AI Life & Wealth Partner", "style": "body_m", "color": "white/55%" },
        "progress_bar": { "width": 120, "height": 3, "fill": "gradient-hero", "radius": "r_full" },
        "background_dots": { "count": 8, "size_range": "2-3px", "opacity": 0.12, "animation": "slow float" }
      },
      "auth_check": "Happens during animation. Navigate at exactly 1500ms regardless.",
      "prompt_for_designer": "First impression of Viya. Must feel like something unprecedented. Dark, alive, intelligent. The orb is the brand's heartbeat — it must breathe."
    },

    "onboarding_language": {
      "id": "OB-001",
      "title": "Language Selection",
      "priority": "P1-CRITICAL",
      "elements": {
        "illustration": "India map with language speech bubbles rising from each state, animated float",
        "headline": "Viya aapki bhasha mein baat karta hai",
        "subtitle": "Pick your language",
        "grid": {
          "columns": 2,
          "gap": 12,
          "tiles": ["🇮🇳 English", "🇮🇳 हिंदी", "தமிழ்", "తెలుగు", "ಕನ್ನಡ", "मराठी"],
          "tile_height": 64,
          "tile_radius": "r_md",
          "selected_bg": "teal_50",
          "selected_border": "2px teal_500",
          "selected_check": "20px circle gradient-hero with white check icon"
        },
        "cta": { "text": "Continue →", "style": "primary", "disabled_until": "language_selected" }
      },
      "prompt_for_designer": "This screen sets the emotional tone. India-first. Warm. The illustration should feel like a celebration of India's linguistic diversity. Every language treated with equal respect."
    },

    "onboarding_phone": {
      "id": "OB-002",
      "title": "Phone Number Input",
      "priority": "P1-CRITICAL",
      "elements": {
        "progress": "4 step dots, step 1 active",
        "headline": "What's your number?",
        "subtitle": "One-time verification. No spam.",
        "input_compound": {
          "height": 68,
          "radius": "r_sm",
          "country_code_width": 100,
          "country_code_content": "flag + code + chevron",
          "phone_input": {
            "font": "JetBrains Mono Medium 20px",
            "auto_focus": true,
            "keyboard_type": "numeric",
            "format": "98765 43210 (space at 5)"
          },
          "states": {
            "focus": "teal_500 border + teal_100 shadow",
            "valid": "emerald_500 border + right checkmark"
          }
        },
        "trust_row": ["🔒 Encrypted", "📵 No spam", "🗑️ Delete anytime"],
        "cta": { "text": "Send Code →", "disabled_until": "valid_10_digits" }
      }
    },

    "onboarding_otp": {
      "id": "OB-003",
      "title": "OTP Verification",
      "priority": "P1-CRITICAL",
      "elements": {
