    "font_scaling": {
      "ios": "Support all Dynamic Type sizes",
      "android": "Support font scale up to 1.3x",
      "test_at": "Largest accessibility size — verify no clipping or overlap"
    },
    "color_independence": {
      "rule": "Never use color as the ONLY indicator of meaning",
      "always_pair_with": "icon + text label + position",
