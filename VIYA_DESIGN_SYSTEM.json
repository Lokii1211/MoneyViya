    "typography": {
      "fonts": {
        "display": {
          "family": "Sora",
          "fallback": ["-apple-system", "BlinkMacSystemFont", "sans-serif"],
          "weights_used": [600, 700, 800],
          "usage": "All headlines and display text. Never below 18px."
        },
        "body": {
          "family": "Inter",
          "fallback": ["-apple-system", "BlinkMacSystemFont", "sans-serif"],
          "weights_used": [400, 500, 600],
          "usage": "All body copy, labels, UI text."
        },
        "numbers": {
          "family": "JetBrains Mono",
          "fallback": ["SF Mono", "Fira Code", "monospace"],
          "weights_used": [400, 500, 600],
          "usage": "EVERY financial number, statistics, amounts. Monospace for alignment."
        },
        "regional": {
          "hindi": "Noto Sans Devanagari",
          "tamil": "Noto Sans Tamil",
          "telugu": "Noto Sans Telugu",
          "kannada": "Noto Sans Kannada",
          "bengali": "Noto Sans Bengali",
          "weights_used": [400, 600],
          "usage": "Regional language content. Same x-height as Inter for visual consistency."
        }
      },
      "scale": {
        "hero":   { "font": "Sora", "weight": 800, "size": 48, "line_height": 56, "letter_spacing": -1.5, "usage": "Splash, celebration screens" },
        "h1":     { "font": "Sora", "weight": 700, "size": 34, "line_height": 42, "letter_spacing": -0.8, "usage": "Primary screen titles" },
        "h2":     { "font": "Sora", "weight": 700, "size": 26, "line_height": 34, "letter_spacing": -0.4, "usage": "Section headers, card titles" },
        "h3":     { "font": "Sora", "weight": 600, "size": 22, "line_height": 30, "letter_spacing": -0.2, "usage": "Sub-section headers, modal titles" },
        "h4":     { "font": "Inter", "weight": 600, "size": 18, "line_height": 26, "letter_spacing": 0,    "usage": "Card headings, emphasized labels" },
        "body_l": { "font": "Inter", "weight": 400, "size": 18, "line_height": 28, "letter_spacing": 0.1,  "usage": "Chat messages, important body copy" },
        "body_m": { "font": "Inter", "weight": 400, "size": 16, "line_height": 24, "letter_spacing": 0.1,  "usage": "Standard body text" },
        "body_s": { "font": "Inter", "weight": 400, "size": 14, "line_height": 20, "letter_spacing": 0.2,  "usage": "Secondary information, timestamps" },
        "label":  { "font": "Inter", "weight": 600, "size": 11, "line_height": 16, "letter_spacing": 1.2,  "transform": "uppercase", "usage": "Category labels, metadata" },
        "num_xl": { "font": "JetBrains Mono", "weight": 700, "size": 48, "line_height": 56, "letter_spacing": -1,   "usage": "Net worth, primary balance, hero numbers" },
        "num_l":  { "font": "JetBrains Mono", "weight": 600, "size": 32, "line_height": 40, "letter_spacing": -0.5, "usage": "Secondary amounts, large stats" },
        "num_m":  { "font": "JetBrains Mono", "weight": 500, "size": 22, "line_height": 30, "letter_spacing": 0,    "usage": "Inline amounts, card numbers" },
        "num_s":  { "font": "JetBrains Mono", "weight": 400, "size": 16, "line_height": 24, "letter_spacing": 0,    "usage": "Small amounts, list amounts" }
      },
      "rules": {
        "indian_number_format": "MANDATORY: ₹1,50,000 not ₹150,000. Always prefix ₹.",
        "negative_amounts": "coral-500 color with − prefix",
        "positive_amounts": "emerald-500 color with + prefix",
        "neutral_amounts": "neutral-900 (light mode) or white (dark mode)",
        "sora_minimum_size": "18px — never use Sora below this size",
        "all_numbers": "ALWAYS JetBrains Mono — never Inter or Sora for numeric data",
        "max_line_length": "72 characters for readability",
        "minimum_body": "14px minimum for any interactive text"
      }
    },

    "spacing": {
