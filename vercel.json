{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "rewrites": [
    { "source": "/api/webhook", "destination": "/frontend/api/webhook.js" },
    { "source": "/api/cron/check-reminders", "destination": "/frontend/api/cron/check-reminders.js" },
    { "source": "/api/cron/daily-report", "destination": "/frontend/api/cron/daily-report.js" },
    { "source": "/((?!api|assets|\\.well-known).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "functions": {
    "api/whatsapp.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 60
    },
    "api/auth/gmail/index.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 15
    },
    "api/auth/gmail/callback.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 30
    },
    "api/sms/process.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 30
    },
    "api/gamification/xp.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 15
    },
    "api/gamification/leaderboard.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 15
    },
    "api/insights/weekly.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 30
    },
    "api/ocr/receipt.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 30
    },
    "api/cron/morning-brief.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 60
    },
    "api/cron/habit-nudge.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 30
    },
    "api/cron/weekly-summary.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 60
    },
    "api/cron/check-reminders.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 30
    },
    "api/cron/medicine-alert.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 30
    },
    "api/cron/monthly-report.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 60
    },
    "frontend/api/webhook.js": {
      "maxDuration": 60
    },
    "frontend/api/cron/check-reminders.js": {
      "maxDuration": 30
    },
    "frontend/api/cron/daily-report.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/morning-brief",
      "schedule": "30 1 * * *"
    },
    {
      "path": "/api/cron/check-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/daily-report",
      "schedule": "30 14 * * *"
    },
    {
      "path": "/api/cron/habit-nudge",
      "schedule": "30 15 * * *"
    },
    {
      "path": "/api/cron/medicine-alert",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/weekly-summary",
      "schedule": "30 14 * * 0"
    },
    {
      "path": "/api/cron/monthly-report",
      "schedule": "30 3 1 * *"
    }
  ]
}
