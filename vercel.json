{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "rewrites": [
    { "source": "/api/webhook", "destination": "/frontend/api/webhook.js" },
    { "source": "/api/cron/check-reminders", "destination": "/frontend/api/cron/check-reminders.js" },
    { "source": "/api/cron/daily-report", "destination": "/frontend/api/cron/daily-report.js" },
    { "source": "/((?!api|assets|\\.well-known).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "functions": {
    "frontend/api/webhook.js": {
      "maxDuration": 60
    },
    "frontend/api/cron/check-reminders.js": {
      "maxDuration": 30
    },
    "frontend/api/cron/daily-report.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/check-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/daily-report",
      "schedule": "30 14 * * *"
    }
  ]
}
